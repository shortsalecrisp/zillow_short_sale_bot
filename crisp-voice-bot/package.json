  "description": "Webhook-driven outbound voice bot between Google Sheets and Telnyx Call Control.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test:sheets": "tsx src/scripts/testSheetWrite.ts",
    "sync:elevenlabs-agent": "tsx src/scripts/syncElevenLabsAgent.ts"
  },
  "keywords": [
    "telnyx",
