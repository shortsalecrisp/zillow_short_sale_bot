ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_AGENT_NAME=Emmy
ELEVENLABS_AGENT_ID=agent_9901kpkhs1cmfgj8w9vm199nc92j
ELEVENLABS_BRANCH_ID=agtbrch_1101kpkhs3b4eg5v0q8ppq4hayks
ELEVENLABS_AGENT_PHONE_NUMBER_ID=
ELEVENLABS_TOOL_SECRET=
