# Server
PORT=3000
BASE_URL=https://your-public-url.ngrok-free.app
VOICE_PROVIDER=telnyx

# Telnyx
# Replace this with your real Telnyx API key. Do not commit real secrets.
TELNYX_API_KEY=replace_me

# These values are included for this first Crisp short-sale voice bot setup.
TELNYX_CALLER_ID=+12176341017
TELNYX_CONNECTION_ID=2941094770216273778
TELNYX_OUTBOUND_VOICE_PROFILE_ID=2941095281015392135

# Google Apps Script writeback
# Deploy the bound Apps Script web app and paste its POST URL here.
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=
GOOGLE_APPS_SCRIPT_TOKEN=

# Live transfer SMS alerts
LIVE_TRANSFER_TEST_MODE=true
LIVE_TRANSFER_NUMBER=+19542053205
LIVE_TRANSFER_FORCE_RESULT=none
YONI_ALERT_SMS_ENABLED=false
YONI_ALERT_DESTINATION_NUMBER=+19542053205
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_ALERT_FROM_NUMBER=+12176341017

# Callback request email alerts
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
