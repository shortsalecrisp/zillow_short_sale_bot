# Apify credentials (reuse existing token variable if already configured)
APIFY_API_TOKEN=
# Optional fallback alias used by some scripts
APIFY_TOKEN=

# Extra Zillow state task IDs fetched directly by the bot (NOT webhook-driven)
APIFY_TASK_MI=
APIFY_TASK_AK=
APIFY_TASK_HI=
APIFY_TASK_MAIN=

# Enable/disable extra MI/AK/HI state searches
APIFY_STATE_SEARCH_ENABLED=true

# Returned-item cap for each state task request
APIFY_STATE_SEARCH_LIMIT=5
APIFY_STATE_SEARCH_FETCH_LIMIT=25
APIFY_STATE_SEARCH_FETCH_LIMIT_MI=50

# Optional request timeout (seconds) for each state task sync call
APIFY_STATE_SEARCH_TIMEOUT_SECONDS=60

# Daily low-cost coverage backstop. Fetches wider search-only windows, de-dupes
# against seen/PendingQueue rows, then details only selected unseen candidates.
APIFY_BACKSTOP_ENABLED=true
APIFY_BACKSTOP_HOUR=18
APIFY_BACKSTOP_MAIN_FETCH_LIMIT=100
APIFY_BACKSTOP_MAIN_LIMIT=10
APIFY_BACKSTOP_STATE_FETCH_LIMIT=50
APIFY_BACKSTOP_STATE_FETCH_LIMIT_MI=150
APIFY_BACKSTOP_STATE_LIMIT=10
APIFY_BACKSTOP_LOCK_PATH=/tmp/apify_coverage_backstop.txt

AUTOREMOTE_KEY=
AUTOREMOTE_ENDPOINT=https://autoremotejoaomgcd.appspot.com
CODEX_AUTOMATION_TOKEN=
