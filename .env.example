# Apify credentials (reuse existing token variable if already configured)
APIFY_API_TOKEN=
# Optional fallback alias used by some scripts
APIFY_TOKEN=

# Extra Zillow state task IDs fetched directly by the bot (NOT webhook-driven)
APIFY_TASK_MI=
APIFY_TASK_AK=
APIFY_TASK_HI=

# Enable/disable extra MI/AK/HI state searches
APIFY_STATE_SEARCH_ENABLED=true

# Returned-item cap for each state task request
APIFY_STATE_SEARCH_LIMIT=5

# Optional request timeout (seconds) for each state task sync call
APIFY_STATE_SEARCH_TIMEOUT_SECONDS=60

AUTOREMOTE_KEY=
AUTOREMOTE_ENDPOINT=https://autoremotejoaomgcd.appspot.com
